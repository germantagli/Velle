# Database
DATABASE_URL="postgresql://user:password@localhost:5432/velle?schema=public"

# JWT
JWT_SECRET=change-this-to-secure-random-string-in-production
JWT_EXPIRES=24h

# CORS
CORS_ORIGINS=http://localhost:3000,https://app.velle.app

# Redis (optional, for queues)
REDIS_URL=redis://localhost:6379

