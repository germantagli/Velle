# Database
DATABASE_URL="postgresql://user:password@localhost:5432/velle?schema=public"

# JWT
JWT_SECRET=change-this-to-secure-random-string-in-production
JWT_EXPIRES=24h

# CORS
CORS_ORIGINS=http://localhost:3000,https://app.velle.app

# URL pública del API (para URLs de archivos subidos en KYC)
# API_BASE_URL=https://velle-developd.up.railway.app

# Redis (optional, for queues)
REDIS_URL=redis://localhost:6379

# Tasa de cambio VES/USDT (usada para conversiones)
VES_USDT_RATE=36

# Dwolla (retiros USA) - opcional, sandbox si no se configura
# DWOLLA_API_KEY=
# DWOLLA_API_SECRET=
# DWOLLA_SANDBOX=true
# DWOLLA_FUNDING_SOURCE_ID=

# Sumsub - Verificación KYC automatizada (documentos + selfie + liveness)
# Obtener credenciales en: https://cockpit.sumsub.com/
# SUMSUB_APP_TOKEN=sbx:xxx...
# SUMSUB_SECRET_KEY=xxx...
# SUMSUB_BASE_URL=https://api.sumsub.com
# SUMSUB_LEVEL_NAME=basic-kyc-level

# Webhook Sumsub: configurar en Dashboard → Webhooks → URL: https://tu-dominio.com/webhooks/sumsub

# AWS S3 - Almacenamiento persistente para documentos KYC (Railway, etc.)
# Crear bucket en https://console.aws.amazon.com/s3/
# Política del bucket: permitir PutObject y GetObject
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=velle-kyc-docs

# External integrations (add when partnering)
# ZELLE_PARTNER_API_URL=
# USDT_PROVIDER_URL=
# KYC_PROVIDER_API_KEY=
# CARD_ISSUER_API_KEY=
