// Velle - Prisma Schema
// Base de datos PostgreSQL para plataforma financiera

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  phone         String?  @unique
  passwordHash  String   @map("password_hash")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  kycStatus     KycStatus @default(PENDING) @map("kyc_status")
  mfaEnabled    Boolean  @default(false) @map("mfa_enabled")
  mfaSecret     String?  @map("mfa_secret")
  limitTierId           String?  @map("limit_tier_id")
  notificationsEnabled  Boolean  @default(false) @map("notifications_enabled")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  wallet        Wallet?
  deviceTokens  DeviceToken[]
  kycDocuments  KycDocument[]
  transactions  Transaction[]
  auditLogs     AuditLog[]
  deposits      Deposit[]
  withdrawals   Withdrawal[]
  limitTier     LimitTier?  @relation(fields: [limitTierId], references: [id])
  limitUsages   LimitUsage[]
  bankAccounts  BankAccount[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  code      String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
}

model LimitTier {
  id               String   @id @default(cuid())
  name             String   @unique
  dailyLimitUsdt   Decimal  @map("daily_limit_usdt") @db.Decimal(18, 6)
  monthlyLimitUsdt Decimal  @map("monthly_limit_usdt") @db.Decimal(18, 6)
  createdAt        DateTime @default(now()) @map("created_at")

  users            User[]
}

model LimitUsage {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  periodType String   @map("period_type")
  periodKey  String   @map("period_key")
  amountUsdt Decimal @map("amount_usdt") @db.Decimal(18, 6)
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodType, periodKey])
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  accountHolder String   @map("account_holder")
  accountNumber String   @map("account_number")
  routingNumber String   @map("routing_number")
  accountType   String   @map("account_type")
  bankName      String?  @map("bank_name")
  lastFour      String   @map("last_four")
  externalId    String?  @unique @map("external_id")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals   Withdrawal[]
}

enum KycStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

model KycDocument {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  type          String   // id_front, id_back, selfie, proof_of_address
  url           String   // S3/secure storage
  status        KycStatus @default(PENDING)
  rejectionReason String? @map("rejection_reason")
  verifiedAt    DateTime? @map("verified_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  balanceVes    Decimal  @default(0) @db.Decimal(18, 2) @map("balance_ves")
  balanceUsdt   Decimal  @default(0) @db.Decimal(18, 6) @map("balance_usdt")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deposit {
  id            String       @id @default(cuid())
  userId        String       @map("user_id")
  amount        Decimal      @db.Decimal(18, 2)
  reference     String       @unique
  status        DepositStatus @default(PENDING)
  createdAt     DateTime     @default(now()) @map("created_at")

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum DepositStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model Withdrawal {
  id                String            @id @default(cuid())
  userId            String            @map("user_id")
  amount            Decimal           @db.Decimal(18, 6)
  destination       String
  destinationEmail  String?           @map("destination_email")
  destinationName   String?           @map("destination_name")
  bankAccountId     String?           @map("bank_account_id")
  partnerTransferId String?           @map("partner_transfer_id")
  usdAmount         Decimal?          @map("usd_amount") @db.Decimal(18, 2)
  fee               Decimal?          @db.Decimal(18, 6)
  etaMinutes        Int?              @map("eta_minutes")
  metadata          Json?
  status            WithdrawalStatus  @default(PENDING)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime?         @updatedAt @map("updated_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount       BankAccount?      @relation(fields: [bankAccountId], references: [id])
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  type          TransactionType
  amount        Decimal  @db.Decimal(18, 6)
  fee           Decimal  @default(0) @db.Decimal(18, 6)
  currency      String   @default("USDT")
  status        TransactionStatus @default(PENDING)
  metadata      Json?    // extra data per type
  recipientId   String?  @map("recipient_id")
  merchantId    String?  @map("merchant_id")
  externalRef   String?  @unique @map("external_ref") // Zelle ref, etc
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id])
}

enum TransactionType {
  P2P
  P2P_VES
  ZELLE_IN
  ZELLE_OUT
  USA_BANK_WITHDRAWAL
  MERCHANT_PAY
  CARD_PAYMENT
  VES_DEPOSIT
  WITHDRAWAL
  CONVERSION_VES_TO_USDT
  CONVERSION_USDT_TO_VES
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  action        String
  resource      String
  resourceId    String?  @map("resource_id")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  user          User?    @relation(fields: [userId], references: [id])
}

model Merchant {
  id            String   @id @default(cuid())
  name          String
  email         String
  documentId    String   @unique @map("document_id")
  walletAddress String?  @map("wallet_address")
  qrCode        String?  @unique @map("qr_code")
  status        String   @default("active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String
  platform  String
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
}

model VirtualCard {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  lastFour      String   @map("last_four")
  brand         String   // visa, mastercard
  expiryMonth   Int      @map("expiry_month")
  expiryYear    Int      @map("expiry_year")
  frozen        Boolean  @default(false)
  externalId    String?  @unique @map("external_id") // Partner card ID
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
}
